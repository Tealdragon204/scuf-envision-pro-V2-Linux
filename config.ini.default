# P2      = B            # rear paddle bottom-right
# P3      = LB           # rear paddle top-left
# P4      = RB           # rear paddle top-right
# S1      = LB           # SAX left grip
# S2      = RB           # SAX right grip
# G1      = SELECT
# G2      = G2
# G3      = G3
# G4      = G4
# G5      = G5
